{
  "manifest_version": 3,
  "name": "ShadowName",
  "version": "1.1.1",
  "description": "Makes your name look different on every website so people searching for you won't find your activity across the web.",
  "permissions": ["storage", "activeTab", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/fingerprint.js", "lib/alias.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ShadowName"
  },
  "web_accessible_resources": [
    {
      "resources": ["homoglyphs.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}
